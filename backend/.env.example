# Backend environment configuration (copy to .env and fill values)
# Used by docker-compose.yml and local Spring Boot runs

# Database
MYSQL_HOST=mysql
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=hospital_management

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT (change this to a long random string in production)
JWT_SECRET=changeitsecurekeyforprodchangekey123456

# External AI API integration (OpenAI)
OPENAI_API_KEY=
OPENAI_API_MODEL=gpt-4o-mini

# Public backend URL for CORS (frontend origin)
CORS_ALLOWED_ORIGINS=http://localhost:3000
